# ─── Database (PostgreSQL — Neon) ───────────────────────────────
# Pooled connection (runtime). From Neon/Vercel integration.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# Direct/unpooled connection (used by `prisma db push` / migrations).
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# ─── NextAuth ───────────────────────────────────────────────────
# Deployed base URL (e.g. https://candidate-dossier.vercel.app). For local dev use http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"
# Random secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
